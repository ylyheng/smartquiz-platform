{
  "info": {
    "name": "SmartQuiz Platform API",
    "description": "Complete API collection for testing all SmartQuiz endpoints.\n\n**Setup:**\n1. Register a user first\n2. Copy the token from the login/register response\n3. Set the `token` variable in the collection variables\n4. All protected endpoints will automatically use the token",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000/api"
    },
    {
      "key": "token",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth", "register"] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Dr. Sarah Chen\",\n  \"email\": \"lecturer@smartquiz.edu\",\n  \"password\": \"password123\",\n  \"role\": \"lecturer\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var res = pm.response.json();",
                  "if (res.data && res.data.token) {",
                  "  pm.collectionVariables.set('token', res.data.token);",
                  "  console.log('Token saved!');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"lecturer@smartquiz.edu\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/auth/me", "host": ["{{baseUrl}}"], "path": ["auth", "me"] },
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "Question Banks",
      "item": [
        {
          "name": "List Banks",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/banks", "host": ["{{baseUrl}}"], "path": ["banks"] },
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Create Bank",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/banks", "host": ["{{baseUrl}}"], "path": ["banks"] },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Data Structures & Algorithms\",\n  \"description\": \"Fundamental concepts of data structures\"\n}"
            }
          }
        },
        {
          "name": "Get Bank by ID",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/banks/1", "host": ["{{baseUrl}}"], "path": ["banks", "1"] },
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Update Bank",
          "request": {
            "method": "PUT",
            "url": { "raw": "{{baseUrl}}/banks/1", "host": ["{{baseUrl}}"], "path": ["banks", "1"] },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"DSA Updated\",\n  \"description\": \"Updated description\"\n}"
            }
          }
        },
        {
          "name": "Delete Bank",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/banks/1", "host": ["{{baseUrl}}"], "path": ["banks", "1"] },
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "Questions",
      "item": [
        {
          "name": "List Questions in Bank",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/banks/1/questions", "host": ["{{baseUrl}}"], "path": ["banks", "1", "questions"] },
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Create MCQ Question",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/banks/1/questions", "host": ["{{baseUrl}}"], "path": ["banks", "1", "questions"] },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"mcq\",\n  \"questionText\": \"What is the time complexity of binary search?\",\n  \"options\": \"A. O(n)\\nB. O(log n)\\nC. O(n^2)\\nD. O(1)\",\n  \"correctAnswer\": \"B\",\n  \"explanation\": \"Binary search halves the search space each step.\",\n  \"points\": 2\n}"
            }
          }
        },
        {
          "name": "Create True/False Question",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/banks/1/questions", "host": ["{{baseUrl}}"], "path": ["banks", "1", "questions"] },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"true-false\",\n  \"questionText\": \"A stack uses FIFO ordering.\",\n  \"correctAnswer\": \"False\",\n  \"explanation\": \"A stack uses LIFO ordering.\",\n  \"points\": 1\n}"
            }
          }
        },
        {
          "name": "Update Question",
          "request": {
            "method": "PUT",
            "url": { "raw": "{{baseUrl}}/banks/1/questions/1", "host": ["{{baseUrl}}"], "path": ["banks", "1", "questions", "1"] },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"mcq\",\n  \"questionText\": \"Updated question text\",\n  \"options\": \"A. Option 1\\nB. Option 2\",\n  \"correctAnswer\": \"A\",\n  \"points\": 3\n}"
            }
          }
        },
        {
          "name": "Delete Question",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/banks/1/questions/1", "host": ["{{baseUrl}}"], "path": ["banks", "1", "questions", "1"] },
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "Quizzes",
      "item": [
        {
          "name": "List Quizzes",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/quizzes", "host": ["{{baseUrl}}"], "path": ["quizzes"] },
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Create Quiz",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/quizzes", "host": ["{{baseUrl}}"], "path": ["quizzes"] },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Data Structures Midterm\",\n  \"description\": \"Covers arrays, linked lists, stacks, and queues\",\n  \"timeLimit\": 30,\n  \"shuffle\": true,\n  \"showResults\": true,\n  \"questionIds\": [1, 2, 3]\n}"
            }
          }
        },
        {
          "name": "Get Quiz by ID",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/quizzes/1", "host": ["{{baseUrl}}"], "path": ["quizzes", "1"] },
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Update Quiz",
          "request": {
            "method": "PUT",
            "url": { "raw": "{{baseUrl}}/quizzes/1", "host": ["{{baseUrl}}"], "path": ["quizzes", "1"] },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Updated Quiz Title\",\n  \"timeLimit\": 45,\n  \"questionIds\": [1, 2]\n}"
            }
          }
        },
        {
          "name": "Delete Quiz",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/quizzes/1", "host": ["{{baseUrl}}"], "path": ["quizzes", "1"] },
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "Attempts",
      "item": [
        {
          "name": "Start Attempt",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/quizzes/1/attempts/start", "host": ["{{baseUrl}}"], "path": ["quizzes", "1", "attempts", "start"] },
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "List My Attempts",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/attempts/mine", "host": ["{{baseUrl}}"], "path": ["attempts", "mine"] },
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Get Attempt",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/attempts/1", "host": ["{{baseUrl}}"], "path": ["attempts", "1"] },
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Submit Attempt",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/attempts/1/submit", "host": ["{{baseUrl}}"], "path": ["attempts", "1", "submit"] },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"answers\": {\n    \"1\": \"B\",\n    \"2\": \"B\",\n    \"3\": \"False\"\n  }\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Analytics",
      "item": [
        {
          "name": "Overview",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/analytics/overview", "host": ["{{baseUrl}}"], "path": ["analytics", "overview"] },
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Quiz Scores",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/analytics/quiz/1/scores", "host": ["{{baseUrl}}"], "path": ["analytics", "quiz", "1", "scores"] },
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Question Breakdown",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/analytics/quiz/1/breakdown", "host": ["{{baseUrl}}"], "path": ["analytics", "quiz", "1", "breakdown"] },
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Student Performance",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/analytics/students", "host": ["{{baseUrl}}"], "path": ["analytics", "students"] },
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/health", "host": ["{{baseUrl}}"], "path": ["health"] }
          }
        }
      ]
    }
  ]
}
